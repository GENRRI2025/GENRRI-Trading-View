# GENRRI Launcher Config
# ─────────────────────────────────────────────────
# MODE: "local"  → starts the server on this computer and opens localhost
#       "remote" → opens your deployed Railway/Render URL directly (no local server needed)
#
MODE=local

# Your deployed URL (only used when MODE=remote)
# Example: https://genrri-production.up.railway.app
REMOTE_URL=https://your-app.up.railway.app
